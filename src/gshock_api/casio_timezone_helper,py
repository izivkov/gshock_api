"""
casio_time_zone_helper.py — Casio timezone table and lookup.

Mirrors the Kotlin CasioTimeZoneHelper object, providing a table of
Casio-supported timezones with DST rules, and a findTimeZone() lookup.
"""

from __future__ import annotations
from datetime import datetime, timezone
from zoneinfo import ZoneInfo

#
# Currently not used
#

class CasioTimeZoneHelper:

    class CasioTimeZone:
        def __init__(self, name: str, zone_name: str, dst_rules: int = 0):
            self.name = zone_name
            self.display_name = name
            self.zone_name = zone_name
            self.zone_id = ZoneInfo(zone_name)

            self.dst_offset: int = self._get_dst_duration_minutes() // 15
            self.offset: int = self._get_standard_offset_minutes() // 15
            # If no DST offset, override dst_rules to 0 (Casio table may be stale)
            self.dst_rules: int = 0 if self.dst_offset == 0 else dst_rules

        def is_in_dst(self) -> bool:
            now = datetime.now(tz=self.zone_id)
            # utcoffset() > utcoffset at standard time → DST is active
            utc_offset = now.utcoffset()
            standard_offset_seconds = self._get_standard_offset_minutes() * 60
            if utc_offset is None:
                return False
            return int(utc_offset.total_seconds()) > standard_offset_seconds

        def has_dst(self) -> bool:
            return self.dst_offset > 0

        def has_rules(self) -> bool:
            return self.dst_rules != 0

        def _get_standard_offset_minutes(self) -> int:
            """
            Standard (non-DST) UTC offset in minutes.
            Uses January 1st which is reliably outside DST for most zones.
            """
            jan = datetime(datetime.now().year, 1, 1, tzinfo=self.zone_id)
            jul = datetime(datetime.now().year, 7, 1, tzinfo=self.zone_id)
            jan_off = jan.utcoffset()
            jul_off = jul.utcoffset()
            if jan_off is None or jul_off is None:
                return 0
            # Standard offset is the lesser of the two (DST adds to it)
            return int(min(jan_off, jul_off).total_seconds()) // 60

        def _get_dst_duration_minutes(self) -> int:
            """
            DST offset duration in minutes (0 if zone has no DST).
            Mirrors Kotlin getDTSDuration().
            """
            jan = datetime(datetime.now().year, 1, 1, tzinfo=self.zone_id)
            jul = datetime(datetime.now().year, 7, 1, tzinfo=self.zone_id)
            jan_off = jan.utcoffset()
            jul_off = jul.utcoffset()
            if jan_off is None or jul_off is None:
                return 0
            diff = int(abs((jul_off - jan_off).total_seconds())) // 60
            return diff

        def __repr__(self) -> str:
            return (
                f"CasioTimeZone(name='{self.display_name}', zone_name='{self.zone_name}', "
                f"offset={self.offset}, dst_offset={self.dst_offset}, dst_rules={self.dst_rules})"
            )

    _timezone_table: list[CasioTimeZone] = []
    _timezone_map: dict[str, CasioTimeZone] = {}
    _initialized: bool = False

