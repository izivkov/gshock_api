    @classmethod
    def _is_equivalent(cls, zone_name_1: str, zone_name_2: str) -> bool:
        """
        Two zones are equivalent if their standard offset, current DST offset,
        and DST transition rules all match — mirrors Kotlin isEquivalent().
        """
        try:
            z1 = ZoneInfo(zone_name_1)
            z2 = ZoneInfo(zone_name_2)
        except Exception:
            return False

        now = datetime.now(timezone.utc)
        jan = datetime(now.year, 1, 1, tzinfo=z1)
        jul = datetime(now.year, 7, 1, tzinfo=z1)

        def offsets(z: ZoneInfo):
            j = datetime(now.year, 1, 1, tzinfo=z).utcoffset()
            u = datetime(now.year, 7, 1, tzinfo=z).utcoffset()
            return j, u

        j1, u1 = offsets(z1)
        j2, u2 = offsets(z2)
        return j1 == j2 and u1 == u2

    @classmethod
    def find_timezone(cls, timezone_name: str) -> CasioTimeZone:
        cls._build_table()

        # Direct match
        found = cls._timezone_map.get(timezone_name)
        if found is not None:
            return found

        # Equivalence match (same offsets + DST pattern)
        for entry in cls._timezone_map.values():
            if cls._is_equivalent(entry.zone_name, timezone_name):
                return entry

        # Fallback: synthetic entry from the timezone name itself
        name = timezone_name.split("/")[-1].upper()
        return cls.CasioTimeZone(name, timezone_name, 0x00)